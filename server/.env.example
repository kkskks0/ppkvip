# ========== 排排看 环境变量模板 ==========
# 复制此文件为 .env 并填入真实密钥
# cp .env.example .env

# 服务端口
PORT=3001

# 数据库（默认 SQLite 文件）
DATABASE_URL="file:./dev.db"

# JWT 签名密钥（生产环境必须修改）
JWT_SECRET="change-me-in-production"

# MiMo AI 视觉分析 API
MIMO_API_KEY="sk-your-mimo-api-key"
MIMO_API_BASE_URL="https://api.xiaomimimo.com/v1"
MIMO_MODEL="mimo-v2.5"

# 微信支付配置
WECHAT_APP_ID=""
WECHAT_MCH_ID="your-mch-id"
WECHAT_API_KEY="your-wechat-api-key"
WECHAT_NOTIFY_URL="https://ppk.shengkangyan.com/api/payment/notify"
WECHAT_CERT_SERIAL_NO="your-cert-serial-no"
WECHAT_PRIVATE_KEY_PATH="./certs/apiclient_key.pem"

# 域名
DOMAIN="ppk.shengkangyan.com"
ICP_RECORD="粤ICP备2026059171号"

# 腾讯云配置
TENCENT_SECRET_ID="your-tencent-secret-id"
TENCENT_SECRET_KEY="your-tencent-secret-key"
TENCENT_REGION="ap-shanghai"
